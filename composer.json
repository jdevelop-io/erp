{
  "name": "jdevelop/erp",
  "type": "project",
  "license": "MIT",
  "authors": [
    {
      "name": "Jean-Denis VIDOT",
      "email": "contact@jdevelop.io"
    }
  ],
  "autoload": {
    "psr-4": {
      "JDevelop\\Erp\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "JDevelop\\Erp\\Test\\Unit\\": "test/unit"
    }
  },
  "scripts": {
    "test": "phpunit --no-coverage",
    "test:coverage:html": "XDEBUG_MODE=coverage phpunit --coverage-html .coverage",
    "test:coverage:text": "XDEBUG_MODE=coverage phpunit --coverage-text --colors=never"
  },
  "require": {
    "php": "^8.3"
  },
  "require-dev": {
    "phpunit/phpunit": "^11.4"
  }
}
